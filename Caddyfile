{
	# TCP only: HTTP/1.1 + HTTP/2. Dropping h3 stops Caddy binding the QUIC/UDP
	# listener and stops it advertising Alt-Svc, so clients stay on TCP. QUIC/UDP
	# stalls on some mobile (Android) network paths; forcing TCP avoids it.
	servers {
		protocols h1 h2
	}
}

example.com {
	handle /uploads/* {
		root * /data
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:3001
	}

	handle {
		encode zstd gzip
		reverse_proxy 127.0.0.1:3000
	}
}
